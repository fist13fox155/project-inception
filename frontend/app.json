{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Talk to JARVIS and send voice transmissions",
        "NSSpeechRecognitionUsageDescription": "Transcribe your voice commands",
        "NSPhotoLibraryUsageDescription": "Send photos and videos in encrypted comms",
        "NSPhotoLibraryAddUsageDescription": "Save received media",
        "NSCameraUsageDescription": "Capture photos and videos in comms",
        "NSLocationWhenInUseUsageDescription": "Pin your position on the tactical map",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Pin your position on the tactical map"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      "expo-secure-store",
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "Send photos and videos in encrypted comms",
          "cameraPermission": "Capture photos and videos in comms"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Pin your position on the tactical map"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
